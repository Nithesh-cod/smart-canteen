# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Run this to generate secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Realtime ────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Role-based access ────────────────────────────────────────────────────────
# Comma-separated roll numbers that receive admin / chef JWT role
ADMIN_ROLLS=ADMIN001
CHEF_ROLLS=CHEF001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL.  Leave blank if backend serves the frontend itself.
FRONTEND_URLS=https://your-app.vercel.app

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
